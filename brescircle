#include <iostream>
#include <GL/glut.h>
using namespace std;
int xc,yc,r;
void Brescircle(int r, int xc, int yc)
{

 int x,y,d;
 x=0;
y=r;
 d=3-(2*r);
 glClear(GL_COLOR_BUFFER_BIT);
glBegin(GL_POINTS);

 do{

 glVertex2d(xc+x,yc+y);
glVertex2d(xc+y,yc+x);
 glVertex2d(xc+y,yc-x);
 glVertex2d(xc+x,yc-y);
 glVertex2d(xc-x,yc-y);
 glVertex2d(xc-y,yc-x);
 glVertex2d(xc-y,yc+x);
 glVertex2d(xc-x,yc+y);

 if(d<0){
 x=x+1;
 d=d+4*x+6;
 }
 else{
 x=x+1;
 y=y-1;
 d=d+4*x-4*y+10;
 }
 }while(x<=y);
 glEnd();
glFlush();

}
