// FIXED DDA LINE FUNCTION
void DdaLine(int xi, int yi, int xf, int yf)
{ int
steps;
int dx = xf
- xi;
int dy = yf
- yi;

 if (abs(dx) >
abs(dy)) steps
= abs(dx); else
steps = abs(dy);

 float xinc =
float(dx) / steps;
float yinc = float(dy) /
steps;

 float x = xi, y = yi;

 glBegin(GL_POINTS);

 glVertex2d(Round(x) + 320, Round(y) + 240);

 for (int i = 0; i < steps; i++)
 { x = x + xinc; y = y + yinc;
glVertex2d(Round(x) + 320, Round(y) + 240);
 }

 glEnd();
}

void mul(float Input[3][10], float s[3][3], float Output[3][10]) {
for (int i = 0; i < 3; i++)
 { for (int
j = 0; j < v; j++)
 {

Output[i][j] = 0;
for (int k = 0; k < 3;
k++)
 {
 Output[i][j] += s[i][k] *
Input[k][j];
 }
 }
 }
}

void Draw()
{
 glClear(GL_COLOR_BUFFER_BIT);

 glColor3f(1, 0, 0);
 DdaLine(-320, 0, 320, 0);
DdaLine(0, -240, 0, 240);

 // Original polygon
(RED) for (int i =
0; i < v; i++)
 {
 DdaLine(Input[0][i], Input[1][i],
 Input[0][(i + 1) % v], Input[1][(i +
1) % v]);
 }

 // Transformed polygon (BLUE)
 glColor3f(0,
0, 1); for
(int i = 0; i <
v; i++)
 {
 DdaLine(Output[0][i], Output[1][i],
 Output[0][(i + 1) % v], Output[1][(i
+ 1) % v]);
 }

 glFlush();
}

